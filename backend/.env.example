APP_NAME=Slate Backend
APP_ENV=development
API_PREFIX=/api/v1
SECRET_KEY=replace-with-a-long-random-secret-key-32-bytes-min
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30

DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/slate
REDIS_URL=redis://localhost:6379/0
CORS_ORIGINS=http://localhost:1420,http://localhost:5173

FRONTEND_OAUTH_SUCCESS_URL=
FRONTEND_OAUTH_FAILURE_URL=

GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=http://localhost:8000/api/v1/auth/oauth/github/callback

GITEE_CLIENT_ID=
GITEE_CLIENT_SECRET=
GITEE_REDIRECT_URI=http://localhost:8000/api/v1/auth/oauth/gitee/callback

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/auth/oauth/google/callback

LLM_DEFAULT_PROVIDER=deepseek
LLM_REQUEST_TIMEOUT_SECONDS=120

LLM_DEEPSEEK_API_KEY=
LLM_DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
LLM_DEEPSEEK_MODELS=deepseek-chat,deepseek-reasoner

LLM_QWEN_API_KEY=
LLM_QWEN_BASE_URL=
LLM_QWEN_MODELS=qwen-plus,qwen-max

LLM_ZHIPU_API_KEY=
LLM_ZHIPU_BASE_URL=
LLM_ZHIPU_MODELS=glm-4-plus,glm-4-air

LLM_DOUBAO_API_KEY=
LLM_DOUBAO_BASE_URL=
LLM_DOUBAO_MODELS=doubao-1-5-pro-32k,doubao-1-5-lite-32k
