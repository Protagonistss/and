{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Slate Editor",
  "version": "0.1.0",
  "identifier": "com.slate.editor",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Slate",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "decorations": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": ""
    },
    "longDescription": "Slate Editor - An intelligent code editor with AI assistance",
    "shortDescription": "AI-powered code editor",
    "resources": [],
    "externalBin": [],
    "copyright": "",
    "category": "DeveloperTool"
  },
  "plugins": {}
}
