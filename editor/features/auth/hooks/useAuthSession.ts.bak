// useAuthSession Hook - 整合 authStore + configStore 逻辑
import { useMemo, useCallback } from 'react';
import { useAuthStore } from '@/stores/authStore';
import { useConfigStore } from '@/stores/configStore';

export interface AuthSessionState {
  // Auth state
  isAuthenticated: boolean;
  accessToken: string | null;
  user: { id: string; email: string } | null;
  isAuthLoading: boolean;
  authError: string | null;

  // Config state
  backendUrl: string;
  currentProvider: string;
  currentModel: string;
  workingDirectory: string;

  // LLM configs
  llmConfigs: Record<string, import('@/stores/configStore').LLMConfig>;
}

export interface AuthSessionActions {
  // Auth actions
  login: () => Promise<void>;
  logout: () => Promise<void>;
  refreshAccessToken: () => Promise<void>;

  // Config actions
  setBackendUrl: (url: string) => void;
  setWorkingDirectory: (path: string) => void;
  setCurrentLLM: (provider: string, model: string) => void;
  updateLLMConfig: (provider: string, config: Partial<import('@/stores/configStore').LLMConfig>) => void;
}

/**
 * 认证会话管理 Hook - 整合 authStore 和 configStore
 */
export function useAuthSession(): AuthSessionState & AuthSessionActions {
  // Auth state
  const accessToken = useAuthStore((state) => state.accessToken);
  const user = useAuthStore((state) => state.user);
  const isAuthLoading = useAuthStore((state) => state.isLoading);
  const authError = useAuthStore((state) => state.error);

  // Auth actions
  const login = useAuthStore((state) => state.login);
  const logout = useAuthStore((state) => state.logout);
  const refreshAccessToken = useAuthStore((state) => state.refreshAccessToken);

  // Config state
  const backendUrl = useConfigStore((state) => state.backendUrl);
  const currentProvider = useConfigStore((state) => state.currentProvider);
  const currentModel = useConfigStore((state) => state.currentModel);
  const workingDirectory = useConfigStore((state) => state.workingDirectory);
  const llmConfigs = useConfigStore((state) => state.llmConfigs);

  // Config actions
  const setBackendUrl = useConfigStore((state) => state.setBackendUrl);
  const setWorkingDirectory = useConfigStore((state) => state.setWorkingDirectory);
  const setCurrentLLM = useConfigStore((state) => state.setCurrentLLM);
  const updateLLMConfig = useConfigStore((state) => state.updateLLMConfig);

  const addToast = useAuthStore((state) => state.addToast || (() => {}));

  // Computed values
  const isAuthenticated = useMemo(() => Boolean(accessToken && !authError), [accessToken, authError]);

  // Wrapped actions with error handling
  const handleLogin = useCallback(async () => {
    try {
      await login();
    } catch (err) {
      addToast({
        type: 'error',
        message: err instanceof Error ? err.message : '登录失败',
      });
    }
  }, [login, addToast]);

  const handleLogout = useCallback(async () => {
    try {
      await logout();
    } catch (err) {
      addToast({
        type: 'error',
        message: err instanceof Error ? err.message : '登出失败',
      });
    }
  }, [logout, addToast]);

  const handleRefreshAccessToken = useCallback(async () => {
    try {
      await refreshAccessToken();
    } catch (err) {
      addToast({
        type: 'error',
        message: err instanceof Error ? err.message : '刷新令牌失败',
      });
    }
  }, [refreshAccessToken, addToast]);

  const handleSetBackendUrl = useCallback(
    (url: string) => {
      setBackendUrl(url);
    },
    [setBackendUrl]
  );

  const handleSetWorkingDirectory = useCallback(
    (path: string) => {
      setWorkingDirectory(path);
    },
    [setWorkingDirectory]
  );

  const handleSetCurrentLLM = useCallback(
    (provider: string, model: string) => {
      setCurrentLLM(provider, model);
    },
    [setCurrentLLM]
  );

  const handleUpdateLLMConfig = useCallback(
    (provider: string, config: Partial<import('@/stores/configStore').LLMConfig>) => {
      updateLLMConfig(provider, config);
    },
    [updateLLMConfig]
  );

  return {
    // State
    isAuthenticated,
    accessToken,
    user,
    isAuthLoading,
    authError,
    backendUrl,
    currentProvider,
    currentModel,
    workingDirectory,
    llmConfigs,

    // Actions
    login: handleLogin,
    logout: handleLogout,
    refreshAccessToken: handleRefreshAccessToken,
    setBackendUrl: handleSetBackendUrl,
    setWorkingDirectory: handleSetWorkingDirectory,
    setCurrentLLM: handleSetCurrentLLM,
    updateLLMConfig: handleUpdateLLMConfig,
  };
}
