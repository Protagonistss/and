// useAgentSession Hook - 整合 agentStore + conversationStore 逻辑
import { useMemo } from 'react';
import { useAgentStore } from '../store';
import { useConversationStore } from '@/stores/conversationStore';

export interface AgentSessionState {
  // Current run state
  currentRun: import('../store/types').AgentRun | null;
  status: import('../store/types').AgentStatus;
  isProcessing: boolean;
  currentStreamContent: string;
  currentToolCalls: import('../store/types').ToolCallRecord[];
  error: string | null;

  // Conversation state
  conversationId: string | null;
  conversations: import('@/stores/conversationStore').Conversation[];
  currentConversation: import('@/stores/conversationStore').Conversation | null;
}

export interface AgentSessionActions {
  // Agent actions
  sendMessage: (content: string) => Promise<void>;
  resumeRun: (instruction?: string) => Promise<void>;
  retryStep: (stepId: string) => void;
  stopGeneration: () => void;

  // Conversation actions
  createConversation: (title?: string) => string;
  selectConversation: (id: string) => void;
  deleteConversation: (id: string) => void;
  renameConversation: (id: string, title: string) => void;
}

/**
 * Agent 会话管理 Hook - 整合 agentStore 和 conversationStore
 * @param conversationId 可选的会话 ID，如果不提供则使用当前选中的会话
 */
export function useAgentSession(conversationId?: string): AgentSessionState & AgentSessionActions {
  // Agent state
  const currentRun = useAgentStore((state) => {
    const targetId = conversationId || state.runsByConversation[conversationId || '']?.conversationId;
    return targetId ? state.runsByConversation[targetId] || null : null;
  });
  const status = useAgentStore((state) => state.status);
  const isProcessing = useAgentStore((state) => state.isProcessing);
  const currentStreamContent = useAgentStore((state) => state.currentStreamContent);
  const currentToolCalls = useAgentStore((state) => state.currentToolCalls);
  const error = useAgentStore((state) => state.error);

  // Agent actions
  const sendMessage = useAgentStore((state) => state.sendMessage);
  const resumeRun = useAgentStore((state) => state.resumeRun);
  const retryStep = useAgentStore((state) => state.retryStep);
  const stopGeneration = useAgentStore((state) => state.stopGeneration);

  // Conversation state
  const conversations = useConversationStore((state) => state.conversations);
  const currentConversationId = useConversationStore((state) => state.currentConversationId);
  const getConversation = useConversationStore((state) => state.getConversation);

  // Conversation actions
  const createConversation = useConversationStore((state) => state.createConversation);
  const selectConversation = useConversationStore((state) => state.selectConversation);
  const deleteConversation = useConversationStore((state) => state.deleteConversation);
  const renameConversation = useConversationStore((state) => state.renameConversation);

  // Computed values
  const activeConversationId = conversationId || currentConversationId;
  const currentConversation = useMemo(
    () => (activeConversationId ? getConversation(activeConversationId) : null),
    [activeConversationId, getConversation]
  );

  // Get the run for the active conversation
  const runForActiveConversation = useAgentStore((state) =>
    activeConversationId ? state.runsByConversation[activeConversationId] || null : null
  );

  return {
    // State
    currentRun: runForActiveConversation,
    status,
    isProcessing,
    currentStreamContent,
    currentToolCalls,
    error,
    conversationId: activeConversationId,
    conversations,
    currentConversation,

    // Actions
    sendMessage,
    resumeRun,
    retryStep,
    stopGeneration,
    createConversation,
    selectConversation,
    deleteConversation,
    renameConversation,
  };
}
